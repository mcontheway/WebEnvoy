{
  "manifest_version": 3,
  "name": "WebEnvoy Native Messaging Bridge (WIP)",
  "version": "0.1.0",
  "description": "Phase 1 minimal bridge skeleton for Native Messaging.",
  "background": {
    "service_worker": "build/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["build/main-world-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["build/content-script.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["nativeMessaging", "storage"]
}
